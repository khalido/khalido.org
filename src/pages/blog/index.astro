---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import ContentList from "@components/ContentList.astro";
import { filterDrafts, getPreview, sortByDate } from "@scripts/content";

const allPosts = await getCollection("blog", filterDrafts);

const allContent = sortByDate(
    await Promise.all(
        allPosts.map(async (post) => ({
            id: post.id,
            collection: "blog" as const,
            data: {
                ...post.data,
                preview: await getPreview(post),
            },
        })),
    ),
);

// Get categories (subfolders) with post counts
const categories = new Map<string, number>();
for (const post of allPosts) {
    const slash = post.id.indexOf("/");
    if (slash !== -1) {
        const cat = post.id.slice(0, slash);
        categories.set(cat, (categories.get(cat) || 0) + 1);
    }
}
const sortedCategories = [...categories.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---

<BaseLayout title="khalido.org: Blog">
    <h1 class="text-3xl mb-4">All Posts</h1>

    {sortedCategories.length > 0 && (
        <div class="flex flex-wrap gap-3 mb-6 text-sm">
            {sortedCategories.map(([cat, count]) => (
                <a href={`/blog/${cat}`} class="text-purple-500 hover:underline hover:bg-yellow-200">
                    {cat} <span class="text-gray-400">({count})</span>
                </a>
            ))}
        </div>
    )}

    <ContentList contents={allContent} />
</BaseLayout>

---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import TagCloud from "@components/TagCloud.astro";
import ContentList from "@components/ContentList.astro";
import { filterDrafts, getPreview, sortByDate, getAllTagsWithCounts } from "@scripts/content";

const [allPosts, allDataStories] = await Promise.all([
  getCollection("blog", filterDrafts),
  getCollection("data", filterDrafts),
]);

const blogContent = await Promise.all(
  allPosts.map(async (post) => ({
    id: post.id,
    collection: "blog" as const,
    data: {
      ...post.data,
      preview: await getPreview(post),
    },
  }))
);

const dataContent = allDataStories.map((story) => ({
  id: story.id,
  collection: "data" as const,
  data: {
    ...story.data,
    preview: story.data.summary || "",
  },
}));

const allContent = sortByDate([...blogContent, ...dataContent]);
const allTags = getAllTagsWithCounts(allPosts, allDataStories);
---

<BaseLayout>
  <div class="lg:flex lg:gap-8">
    <div class="lg:w-3/4">
      <ContentList contents={allContent} />
    </div>
    <aside class="hidden lg:block lg:w-1/4">
      <div class="sticky top-4">
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-2">Tags</h2>
        <TagCloud tags={allTags} />
      </div>
    </aside>
  </div>
</BaseLayout>

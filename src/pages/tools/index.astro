---
import BaseLayout from "@layouts/BaseLayout.astro";
import ToolsList from "./_ToolsList.svelte";
---

<BaseLayout title="Tools - khalido.org" description="Useful web tools">
  <div class="relative">
    <div class="max-w-2xl">
      <h1 class="text-3xl font-bold mb-2">Tools</h1>
      <p class="text-gray-500 text-sm mb-6">
        Miscellaneous HTML+JavaScript tools built mostly with the help of LLMs. A mix of experiments and useful things I actually use.
      </p>
    </div>

    <ToolsList client:only="svelte" />
  </div>
</BaseLayout>

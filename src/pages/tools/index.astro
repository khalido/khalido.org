---
import BaseLayout from "@layouts/BaseLayout.astro";

const tools = [
    {
        name: "Unwall",
        description: "Try to bypass article paywalls via archive and cache services",
        url: "/tools/unwall",
    },
    {
        name: "Timezone Converter",
        description: "Compare two timezones side by side with day/night overlap",
        url: "/tools/timezone-converter",
    },
    {
        name: "Word Counter",
        description: "Count words and characters in text",
        url: "/tools/word-counter",
    },
];
---

<BaseLayout title="Tools - khalido.org" description="Useful web tools">
    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold mb-6">Tools</h1>

        <div class="grid gap-4 md:grid-cols-2">
            {
                tools.map((tool) => (
                    <a
                        href={tool.url}
                        class="block p-5 border border-gray-200 rounded-lg hover:border-gray-400 transition-colors"
                    >
                        <h2 class="text-lg font-semibold mb-1">{tool.name}</h2>
                        <p class="text-gray-600 text-sm">{tool.description}</p>
                    </a>
                ))
            }
        </div>

        <p class="mt-6 text-sm text-gray-400">
            <a href="/tools/settings" class="hover:text-gray-600">⚙ Settings</a> — manage API keys for tools
        </p>
    </div>
</BaseLayout>

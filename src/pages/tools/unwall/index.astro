---
import BaseLayout from "@layouts/BaseLayout.astro";
import Unwall from "./_Unwall.svelte";
---

<BaseLayout title="Unwall - khalido.org" description="Try to bypass article paywalls.">
  <h1 class="text-2xl font-bold mb-2">Unwall</h1>
  <p class="text-gray-600 mb-4 text-sm">Paste a paywalled article URL and try multiple archive/cache services.</p>
  <Unwall client:load />
</BaseLayout>

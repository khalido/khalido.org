---
import BaseLayout from "@layouts/BaseLayout.astro";
import TimeCompare from "./_TimeCompare.svelte";
---

<BaseLayout
  title="Timezone Converter - khalido.org"
  description="Compare times across two timezones with overlap highlighting."
>
  <h1 class="text-2xl font-bold mb-2">Timezone Converter</h1>
  <p class="text-gray-600 mb-4 text-sm">Compare two timezones side by side. Green rows show when both locations are awake (8am–9pm).</p>
  <TimeCompare client:load />
</BaseLayout>

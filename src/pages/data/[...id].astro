---
import { getCollection, render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import FormattedDate from "@components/FormattedDate.astro";

export async function getStaticPaths() {
  const stories = await getCollection("data");
  return stories.map((story) => ({
    params: { id: story.id },
    props: story,
  }));
}

const story = Astro.props;
const { Content } = await render(story);
---

<BaseLayout title={story.data.title}>
  <article class="max-w-5xl mx-auto">
    <header class="mb-8">
      <h1 class="text-3xl font-bold mb-2">{story.data.title}</h1>
      <div class="text-sm text-gray-500">
        <FormattedDate date={story.data.updated || story.data.date} />
        {" / "}
        {story.data.tags.map((tag, i) => (
          <>
            <a class="text-purple-400 hover:underline" href={`/tags/${tag}`}>{tag}</a>
            {i < story.data.tags.length - 1 && ", "}
          </>
        ))}
      </div>
    </header>
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>

---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import FormattedDate from "@components/FormattedDate.astro";
import { sortByDate } from "@scripts/content";

const stories = await getCollection("data", ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const sortedStories = sortByDate(stories);
---

<BaseLayout title="Data Stories">
  <h1 class="text-3xl mb-2">Data Stories</h1>
  <p class="text-gray-600 mb-8">Interactive, data-driven explorations of topics I find interesting.</p>

  <div class="grid gap-6 md:grid-cols-2">
    {sortedStories.map((story) => (
      <a
        href={`/data/${story.id}`}
        class="block p-6 bg-white border border-gray-200 rounded-lg hover:shadow-md transition-shadow no-underline"
      >
        <h2 class="text-xl font-semibold text-gray-800 mb-2">{story.data.title}</h2>
        {story.data.summary && (
          <p class="text-gray-600 text-sm mb-3">{story.data.summary}</p>
        )}
        <div class="text-xs text-gray-400">
          <FormattedDate date={story.data.updated || story.data.date} />
          {" / "}
          {story.data.tags.map((tag, i) => (
            <>
              <span class="text-purple-400">{tag}</span>
              {i < story.data.tags.length - 1 && ", "}
            </>
          ))}
        </div>
      </a>
    ))}
  </div>
</BaseLayout>

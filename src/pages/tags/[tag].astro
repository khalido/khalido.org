---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import ContentList from "@components/ContentList.astro";
import { filterDrafts, getPreview, sortByDate } from "@scripts/content";

export async function getStaticPaths() {
    const [posts, dataStories] = await Promise.all([
        getCollection("blog", filterDrafts),
        getCollection("data", filterDrafts),
    ]);
    const allEntries = [...posts, ...dataStories];
    const tags = [...new Set(allEntries.flatMap((post) => post.data.tags))];

    return tags.map((tag) => ({
        params: { tag },
        props: { tag },
    }));
}

const { tag } = Astro.props;

const [allPosts, allDataStories] = await Promise.all([
    getCollection("blog", filterDrafts),
    getCollection("data", filterDrafts),
]);

// Posts with this tag
const taggedPosts = allPosts.filter((post) => post.data.tags?.includes(tag));
const taggedStories = allDataStories.filter((story) => story.data.tags?.includes(tag));
const allTagged = [...taggedPosts, ...taggedStories];

// Related tags: other tags on these posts, sorted by frequency
const tagCounts = new Map<string, number>();
for (const entry of allTagged) {
    for (const t of entry.data.tags) {
        if (t !== tag) tagCounts.set(t, (tagCounts.get(t) || 0) + 1);
    }
}
const relatedTags = [...tagCounts.entries()]
    .sort((a, b) => b[1] - a[1])
    .map(([t, count]) => ({ tag: t, count }));

// Prepare content feed
const blogContent = await Promise.all(
    taggedPosts.map(async (post) => ({
        id: post.id,
        collection: "blog" as const,
        data: {
            ...post.data,
            preview: await getPreview(post),
        },
    })),
);
const dataContent = taggedStories.map((story) => ({
    id: story.id,
    collection: "data" as const,
    data: {
        ...story.data,
        preview: story.data.summary || "",
    },
}));
const tagContent = sortByDate([...blogContent, ...dataContent]);
---

<BaseLayout title={`khalido.org: ${tag}`}>
    <h1 class="text-3xl mb-4">
        {tagContent.length} posts about "{tag}"
    </h1>

    {relatedTags.length > 0 && (
        <div class="mb-6 flex flex-wrap gap-2 items-center">
            <span class="text-sm text-gray-400 mr-1">also tagged:</span>
            {relatedTags.map(({ tag: t, count }) => (
                <button
                    class="tag-filter px-2 py-0.5 text-sm rounded-full border border-gray-300 text-gray-600 hover:border-purple-400 hover:text-purple-600 transition-colors"
                    data-tag={t}
                >
                    {t} <span class="text-gray-400">({count})</span>
                </button>
            ))}
        </div>
    )}

    <ContentList contents={tagContent} />
</BaseLayout>

<script>
    document.querySelectorAll(".tag-filter").forEach((btn) => {
        btn.addEventListener("click", () => {
            const tag = (btn as HTMLElement).dataset.tag!;
            btn.classList.toggle("bg-purple-100");
            btn.classList.toggle("border-purple-400");
            btn.classList.toggle("text-purple-700");
            document.dispatchEvent(new CustomEvent("toggle-tag-filter", { detail: { tag } }));
        });
    });
</script>

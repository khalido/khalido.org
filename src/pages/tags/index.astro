---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import TagCloud from "@components/TagCloud.astro";
import { filterDrafts, getAllTagsWithCounts } from "@scripts/content";

const [allPosts, allDataStories] = await Promise.all([
    getCollection("blog", filterDrafts),
    getCollection("data", filterDrafts),
]);

const allTags = getAllTagsWithCounts(allPosts, allDataStories);
const totalPosts = allPosts.length + allDataStories.length;
---

<BaseLayout title="khalido.org: Tags">
    <h1 class="text-3xl mb-2">Tags</h1>
    <p class="text-sm text-gray-400 mb-6">{totalPosts} posts across {allTags.length} tags</p>
    <TagCloud tags={allTags} />
</BaseLayout>

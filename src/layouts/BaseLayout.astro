---
import BaseHead from "@components/BaseHead.astro";
import Footer from "@components/Footer.astro";
import "@styles/global.css";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import Breadcrumbs from "@components/Breadcrumbs.astro";

// Define interface for the layout props
interface Props {
  title?: string;
  description?: string;
  image?: string;
  fullWidth?: boolean;
}

// Destructure props with defaults
const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  image,
  fullWidth = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body>
    <div class="bg-yellow-100">
      <div class:list={[fullWidth ? "px-4 sm:px-6" : "max-w-3xl mx-auto px-4 sm:px-6 md:px-7 lg:max-w-4xl lg:px-8 xl:max-w-5xl xl:px-9"]}>
        <header class="flex items-baseline justify-between py-3">
          <a href="/" class="text-xl font-mono tracking-wider font-extrabold text-gray-800 hover:text-gray-600"
            >{SITE_TITLE}</a
          >
          <nav class="flex gap-4 text-sm text-gray-500">
            <a href="/about" class="hover:text-gray-800">about</a>
            <a href="/tags" class="hover:text-gray-800">tags</a>
            <a href="/tools" class="hover:text-gray-800">tools</a>
          </nav>
        </header>
      </div>
    </div>

    {fullWidth ? (
      <main>
        <slot />
      </main>
    ) : (
      <div class="max-w-3xl mx-auto px-4 sm:px-6 md:px-7 lg:max-w-4xl lg:px-8 xl:max-w-5xl xl:px-9">
        <main class="py-5">
          <Breadcrumbs />
          <slot />
        </main>

        <Footer />
      </div>
    )}
  </body>
</html>
